# NanoClaw Configuration
# Copy this to .env and fill in your values.

# --- Required ---
# Choose ONE authentication method:
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...

# --- Channels (at least one required) ---
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_BOT_POOL=token1,token2,token3  # For agent swarms

# --- Optional ---
ASSISTANT_NAME=Andy
TZ=America/New_York

# Tile owner namespace for tessl registry
TILE_OWNER=nanoclaw

# --- Docker-out-of-Docker (for NAS/server deployment) ---
# NAS_HOST=your-nas-ip
# NAS_PROJECT_DIR=/path/to/nanoclaw
# HOST_PROJECT_ROOT=/path/to/nanoclaw
# HOST_UID=1000
# HOST_GID=1000

# --- External integrations (for host scripts) ---
# OPENAI_API_KEY=sk-...          # Whisper transcription
# COMPOSIO_API_KEY=...           # Composio MCP tools
# GITHUB_TOKEN=ghp_...           # Backup push, promote script
