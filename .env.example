# Repository secrets are managed in GitHub Actions:
# https://github.com/jbaruch/nanoclaw-public/settings/secrets/actions
#
# The variables below are CI-only secrets read by the policy-review
# workflows in .github/workflows/. They are not consumed at runtime by
# the local NanoClaw process.

# OpenAI billing account for the Codex-engine policy reviewer
# (.github/workflows/review-openai.lock.yml).
OPENAI_API_KEY=sk-...

# Anthropic billing account for the Claude Code policy reviewer
# (.github/workflows/review-anthropic.lock.yml).
ANTHROPIC_API_KEY=sk-ant-...

# tessl install authentication for fetching jbaruch/coding-policy at
# review time. Create at https://tessl.io/account/api-keys.
TESSL_TOKEN=...
